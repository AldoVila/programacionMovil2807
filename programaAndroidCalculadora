1. Main Activity
package com.example.calculadora;

import android.app.Activity;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;

public class MainActivity extends Activity implements View.OnClickListener {

    private EditText pantalla;
    private Button[] btnDigitos = new Button[10];
    private Button btnSuma, btnResta, btnMulti, btnDiv;
    private Button btnPunto, btnIgual, btnClear;

    private double op1 = 0, op2 = 0;
    private char   operacion       = ' ';
    private boolean pintarPunto    = true;
    private boolean operacionLista = false; // true: ya se pulsó un operador

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        pantalla = findViewById(R.id.pantalla);

        int[] ids = {
            R.id.btn0, R.id.btn1, R.id.btn2, R.id.btn3, R.id.btn4,
            R.id.btn5, R.id.btn6, R.id.btn7, R.id.btn8, R.id.btn9
        };
        for (int i = 0; i <= 9; i++) {
            btnDigitos[i] = findViewById(ids[i]);
            btnDigitos[i].setOnClickListener(this);
        }

        btnSuma   = findViewById(R.id.btnSuma);
        btnResta  = findViewById(R.id.btnResta);
        btnMulti  = findViewById(R.id.btnMulti);
        btnDiv    = findViewById(R.id.btnDiv);
        btnPunto  = findViewById(R.id.btnPunto);
        btnIgual  = findViewById(R.id.btnIgual);
        btnClear  = findViewById(R.id.btnClear);

        btnSuma .setOnClickListener(this);
        btnResta.setOnClickListener(this);
        btnMulti.setOnClickListener(this);
        btnDiv  .setOnClickListener(this);
        btnPunto.setOnClickListener(this);
        btnIgual.setOnClickListener(this);
        btnClear.setOnClickListener(this);
    }

    @Override
    public void onClick(View v) {

        /* ── Dígitos 0-9 ── */
        for (int i = 0; i <= 9; i++) {
            if (v == btnDigitos[i]) {
                pantalla.setText(pantalla.getText() + String.valueOf(i));
                return;
            }
        }

        if (v == btnPunto) {
            if (pintarPunto) {
                String actual = pantalla.getText().toString();
                pantalla.setText(actual.isEmpty() ? "0." : actual + ".");
                pintarPunto = false;
            }
            return;
        }

        if (v == btnSuma || v == btnResta || v == btnMulti || v == btnDiv) {
            String texto = pantalla.getText().toString();
            if (texto.isEmpty()) return;

            op1 = Double.parseDouble(texto);
            pantalla.setText("");
            pintarPunto    = true;
            operacionLista = true;

            if (v == btnSuma)  operacion = '+';
            if (v == btnResta) operacion = '-';
            if (v == btnMulti) operacion = '*';
            if (v == btnDiv)   operacion = '/';
            return;
        }

        if (v == btnIgual) {
            String texto = pantalla.getText().toString();
            if (texto.isEmpty() || !operacionLista) return;

            op2 = Double.parseDouble(texto);
            double res = calcular(op1, op2, operacion);

            if (Double.isNaN(res)) {
                pantalla.setText("Error");
            } else if (res == Math.floor(res) && !Double.isInfinite(res)) {
                pantalla.setText(String.valueOf((long) res)); // evita "3.0"
            } else {
                pantalla.setText(String.valueOf(res));
            }

            pintarPunto    = true;
            operacionLista = false;
            return;
        }

        if (v == btnClear) {
            reiniciar();
        }
    }

    private double calcular(double a, double b, char op) {
        switch (op) {
            case '+': return a + b;
            case '-': return a - b;
            case '*': return a * b;
            case '/': return (b == 0) ? Double.NaN : a / b;
            default:  return Double.NaN;
        }
    }

    private void reiniciar() {
        pantalla.setText("");
        op1 = op2 = 0;
        operacion      = ' ';
        pintarPunto    = true;
        operacionLista = false;
    }
}
