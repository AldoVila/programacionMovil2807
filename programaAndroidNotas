3. Note Adapter
package com.notas.app

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView

class NoteAdapter(
    private var notes: List<Note>,
    private val onSelect: (Note) -> Unit
) : RecyclerView.Adapter<NoteAdapter.NoteViewHolder>() {

    private var selectedPosition = -1

    class NoteViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val title: TextView = view.findViewById(R.id.titleText)
        val content: TextView = view.findViewById(R.id.contentText)
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): NoteViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_note, parent, false)
        return NoteViewHolder(view)
    }

    override fun onBindViewHolder(holder: NoteViewHolder, position: Int) {
        val note = notes[position]

        holder.title.text = note.title
        holder.content.text = note.content

        holder.itemView.isSelected = position == selectedPosition

        holder.itemView.setOnClickListener {
            selectedPosition = position
            notifyDataSetChanged()
            onSelect(note)
        }
    }

    override fun getItemCount(): Int = notes.size

    fun updateList(newList: List<Note>) {
        notes = newList
        selectedPosition = -1
        notifyDataSetChanged()
    }
}

4. File Manager
package com.notas.app

import android.content.ContentValues
import android.content.Context
import android.provider.MediaStore
import java.io.File

object FileManager {

    fun saveInternal(context: Context, note: Note) {
        val file = File(context.filesDir, "${note.title}.txt")
        file.writeText(note.content)
    }

    fun saveExternalApp(context: Context, note: Note) {
        val dir = context.getExternalFilesDir("notes") ?: context.filesDir
        val file = File(dir, "${note.title}.txt")
        file.writeText(note.content)
    }

    fun delete(context: Context, note: Note) {
        val file1 = File(context.filesDir, "${note.title}.txt")
        val file2 = File(context.getExternalFilesDir("notes") ?: context.filesDir, "${note.title}.txt")

        if (file1.exists()) file1.delete()
        if (file2.exists()) file2.delete()
    }

    fun getNotes(context: Context): List<Note> {
        val dir = context.filesDir

        return dir.listFiles()?.map {
            Note(
                title = it.nameWithoutExtension,
                content = it.readText()
            )
        } ?: emptyList()
    }

    fun exportToDownloads(context: Context, note: Note) {
        val values = ContentValues().apply {
            put(MediaStore.Downloads.DISPLAY_NAME, "${note.title}.txt")
            put(MediaStore.Downloads.MIME_TYPE, "text/plain")
        }

        val uri = context.contentResolver.insert(
            MediaStore.Downloads.EXTERNAL_CONTENT_URI,
            values
        )

        uri?.let {
            context.contentResolver.openOutputStream(it)?.use { stream ->
                stream.write(note.content.toByteArray())
            }
        }
    }
}

