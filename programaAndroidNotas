1. Main Activity
package com.notas.app

import android.os.Bundle
import android.widget.*
import androidx.appcompat.app.AppCompatActivity
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView

class MainActivity : AppCompatActivity() {

    private lateinit var adapter: NoteAdapter
    private var selectedNote: Note? = null

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val title = findViewById<EditText>(R.id.titleInput)
        val content = findViewById<EditText>(R.id.contentInput)

        val btnSave = findViewById<Button>(R.id.btnSave)
        val btnDelete = findViewById<Button>(R.id.btnDelete)
        val btnExportInternal = findViewById<Button>(R.id.btnExportInternal)
        val btnExportExternal = findViewById<Button>(R.id.btnExportExternal)
        val btnExportDownloads = findViewById<Button>(R.id.btnExportDownloads)

        val recycler = findViewById<RecyclerView>(R.id.recycler)

        recycler.layoutManager = LinearLayoutManager(this)

        adapter = NoteAdapter(emptyList()) { note: Note ->
            selectedNote = note
            Toast.makeText(this, "Seleccionada: ${note.title}", Toast.LENGTH_SHORT).show()
        }

        recycler.adapter = adapter

        fun refresh() {
            val notes = FileManager.getNotes(this)
            adapter.updateList(notes)
        }

        btnSave.setOnClickListener {
            val note = Note(title.text.toString(), content.text.toString())

            FileManager.saveInternal(this, note)
            refresh()

            title.text.clear()
            content.text.clear()
        }

        btnDelete.setOnClickListener {
            selectedNote?.let {
                FileManager.delete(this, it)
                selectedNote = null
                refresh()
            }
        }

        btnExportInternal.setOnClickListener {
            selectedNote?.let {
                FileManager.saveInternal(this, it)
                Toast.makeText(this, "Guardado interno", Toast.LENGTH_SHORT).show()
            }
        }

        btnExportExternal.setOnClickListener {
            selectedNote?.let {
                FileManager.saveExternalApp(this, it)
                Toast.makeText(this, "Guardado externo", Toast.LENGTH_SHORT).show()
            }
        }

        btnExportDownloads.setOnClickListener {
            selectedNote?.let {
                FileManager.exportToDownloads(this, it)
                Toast.makeText(this, "Exportado a Downloads", Toast.LENGTH_SHORT).show()
            }
        }

        refresh()
    }
}

